// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Budget {
  id               String    @id
  totalValue       Float     @map("valueTotal")
  status           String?   @map("statusId")
  approved         Boolean   @default(false)
  payments         Payment[]
  items            Item[]
  companyId        String
  customerId       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime? @updatedAt
  
  @@map("budgets")
}

model Item {
  id          String   @id
  budgetId    String   @map("budgetId")
  budget      Budget   @relation(fields: [budgetId], references: [id])
  serviceName String
  value       Float
  
  @@map("budgets_items")
}

model Payment {
  id       String @id
  budgetId String @map("budgetId")
  budget   Budget @relation(fields: [budgetId], references: [id])
  method   String @map("methodId")
  amount   Float  @map("value")
  
  @@map("budgets_payments")
}

model Receipt {
  id          String   @id
  description String
  value       Float
  createdAt   DateTime @default(now())
  
  @@map("receipts")
}

model Company {
  id    String @id
  name  String
  
  @@map("companies")
}

model Customer {
  id   String @id
  name String
  
  @@map("customers")
}
